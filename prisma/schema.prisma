generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  description String
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  category    String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum TransactionType {
  INCOME
  EXPENSE
}
